{
  "name": "nudge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "worker:dev": "wrangler dev",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc -p worker/tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "db:init": "wrangler d1 execute nudge --local --file=worker/schema.sql",
    "db:init:remote": "wrangler d1 execute nudge --remote --file=worker/schema.sql",
    "deploy": "vite build && wrangler deploy"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "wrangler": "^4.104.0"
  }
}
